# ── Paths ─────────────────────────────────────────────────────────────────────
# Absolute path to the tickets root directory
TICKETS_BASE_PATH=../tickets

# Absolute path to the app Claude will work on.
# Gemini reads source files here to build implementation plans.
APP_BASE_PATH=/Users/joaocaetano/Development/TravelApp/Application/XCode

# Full path to the claude CLI binary (auto-detected via PATH if omitted)
# Run `which claude` in your terminal to find the path if launch fails with ENOENT.
# CLAUDE_BINARY=/usr/local/bin/claude

# Claude authenticates via your local CLI session (run `claude` once to log in).
# No API key is required.

# Full path to the gh CLI binary (auto-detected via PATH if omitted)
# Run `which gh` to find it. Required for push and PR creation steps.
# Prerequisite: run `gh auth login` once before using this feature.
# GH_BINARY=/opt/homebrew/bin/gh

# ── Gemini Flash ──────────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The spreadsheet ID from the URL: /spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEETS_ID=1x519i1iO1qjPqmDTYzhRcO58-8OUGZAvXjzNHffQOus

# Service account credentials (create at console.cloud.google.com → IAM)
# Share the spreadsheet with the service account email as an Editor
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
